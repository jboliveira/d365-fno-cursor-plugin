{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CURSOR_PLUGIN_ROOT}/hooks/xpp-fno-session-start.ps1\"",
        "timeout": 15
      }
    ],
    "preToolUse": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CURSOR_PLUGIN_ROOT}/hooks/xpp-fno-pre-write.ps1\"",
        "matcher": "Write|StrReplace",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CURSOR_PLUGIN_ROOT}/hooks/xpp-fno-post-write.ps1\"",
        "matcher": "Write|StrReplace",
        "timeout": 10
      }
    ],
    "subagentStop": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CURSOR_PLUGIN_ROOT}/hooks/xpp-fno-subagent-stop.ps1\"",
        "matcher": "xpp-fno-implementer",
        "loop_limit": 1,
        "timeout": 10
      }
    ]
  }
}
